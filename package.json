{
  "name": "u",
  "private": true,
  "version": "0.1.0",
  "description": "U - MCP-first second-brain platform",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @u/mcp-server dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @u/db db:generate",
    "db:push": "pnpm --filter @u/db db:push",
    "db:seed": "pnpm --filter @u/db db:seed"
  },
  "devDependencies": {
    "@types/node": "^22.7.7"
  }
}
