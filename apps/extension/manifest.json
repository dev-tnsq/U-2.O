{
  "manifest_version": 3,
  "name": "U Capture",
  "description": "Capture pages, links, and notes into U memory.",
  "version": "0.1.0",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to U"
  },
  "options_page": "options.html"
}
