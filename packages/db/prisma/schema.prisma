generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  name         String?
  cards        Card[]
  notes        Note[]
  ingestionJobs IngestionJob[]
  apiKeys      ApiKey[]
  idempotencyRecords IdempotencyRecord[]
  mcpAuditLogs  McpAuditLog[]
  graphPresets Json?
  createdAt    DateTime  @default(now())
}

model Card {
  id              String       @id @default(cuid())
  title           String
  sourceType      String
  originalUrl     String?
  originalContent String?
  summary         String
  keyPoints       Json?
  tags            String[]
  embeddings      Unsupported("vector(1536)")?
  notebook        Json
  connectionsMeta Json?
  createdAt       DateTime     @default(now())
  lastReviewedAt  DateTime?
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outgoing        Connection[] @relation("FromConnections")
  incoming        Connection[] @relation("ToConnections")

  @@index([tags])
}

model Connection {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  reason    String
  weight    Float    @default(1.0)
  from      Card     @relation("FromConnections", fields: [fromId], references: [id], onDelete: Cascade)
  to        Card     @relation("ToConnections", fields: [toId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([fromId])
  @@index([toId])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  blocks    Json
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum IngestionJobType {
  URL
  NOTE
}

enum IngestionJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model IngestionJob {
  id           String             @id @default(cuid())
  userId       String
  type         IngestionJobType
  status       IngestionJobStatus @default(PENDING)
  payload      Json
  attempts     Int                @default(0)
  errorMessage String?
  resultCardId String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  startedAt    DateTime?
  finishedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ApiKey {
  id         String   @id @default(cuid())
  userId     String
  label      String
  keyHash    String   @unique
  isActive   Boolean  @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

model IdempotencyRecord {
  id             String   @id @default(cuid())
  userId         String
  endpoint       String
  idempotencyKey String
  responseCode   Int
  responseBody   Json
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint, idempotencyKey])
  @@index([userId, createdAt])
}

model McpAuditLog {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String?
  toolName    String
  success     Boolean
  errorMessage String?
  durationMs  Int?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([toolName, createdAt])
}
